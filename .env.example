# CorreSeguro - Variables de entorno sensibles
# Copia este archivo como .env y rellena los valores reales.
# IMPORTANTE: NO subir el archivo .env a control de versiones (git)

# Email SMTP
# Para Gmail: smtp.gmail.com / 587 / tls
# Para IONOS: smtp.ionos.es / 587 / tls
# Para @belsue.es en IONOS: smtp.ionos.es / 587 / tls
MAIL_HOST=smtp.ionos.es
MAIL_PORT=587
MAIL_SECURE=tls
MAIL_USERNAME=info@correseguro.es
MAIL_PASSWORD=tu_password_aqui
MAIL_FROM=info@correseguro.es
MAIL_FROM_NAME=CorreSeguro
MAIL_TO_INTERNAL=soporteit@belsue.es

# Groq AI API
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
